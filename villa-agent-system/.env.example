PORT=3001

# Dev mode: return response synchronously from /chat
DEV_SYNC=1

# OpenAI (agents)
OPENAI_API_KEY=your_key_here
MODEL_TRIAGE=gpt-4.1-mini
MODEL_PLANNER=gpt-4.1-mini
MODEL_BOOKING=gpt-4.1-mini

# Async mode (only when DEV_SYNC=0)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/villa
REDIS_URL=redis://localhost:6379
EVENT_STREAM=workflow-events
EVENT_GROUP=workers
